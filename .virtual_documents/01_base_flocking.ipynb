import numpy as np
from matplotlib import pyplot as plt
from matplotlib import animation
from matplotlib.patches import Ellipse, Circle
from IPython.display import HTML
from matplotlib import rc



# 1. Parameters
N = 300                             # Total number of boids
limits = np.array([5000, 5000])     # Size of 2D world: [width, height]

neighbor_radius = 70                # How far a boid can see
separation_weight = 1.5             # Strength of avoidance
alignment_weight = 0.5              # Strength of velocity matching
cohesion_weight = 0.1               # Strength of group attraction

# Confirm setup
print(f"{N} boids, world size = {limits}")



# 2. Generate random boids
def new_flock(count, lower_limits, upper_limits):
    width = upper_limits - lower_limits     # Computes range in both x and y
    return lower_limits[:, np.newaxis] + np.random.rand(2, count) * width[:, np.newaxis]    # Creates count number of 2D points

# 3. Initial positions and velocities
positions = new_flock(N, np.array([800, 800]), np.array([1100, 1100]))
velocities = new_flock(N, np.array([0, -20]), np.array([10, 20]))

# Visualize initial scatter
plt.figure(figsize=(6,6))
plt.scatter(positions[0], positions[1], s=10)
plt.title("Initial Boid Positions")
plt.xlabel("x")
plt.ylabel("y")
plt.show()

positions
velocities



# 4. Update position
def update_boids(positions, velocities):
    positions += velocities      # Uses vectorized addition between two 2xN arrays

# 5. Boundary Collision
def apply_boundary_collision(positions, velocities, limits):
    for dim in range(2):                               # Loop over two axis i=0 for x, i=1 for y
        too_low = positions[dim, :] < 0                # Checks which boids are below the lower limit (0, 0)
        too_high = positions[dim, :] > limits[dim]     # Checks which boids are above the upper limit (2000, 2000)
        velocities[dim, too_low | too_high] *= -1      # Flips velocity of out of bounds boids detecting using logical OR operation
        positions[dim, too_low] = 1                    # Moves the out of bound boid back to (0, 0)
        positions[dim, too_high] = limits[dim] - 1     # Moves the out of bound boid back to (2000, 2000)

print("Boundary and update functions ready.")

positions


# 6. Flocking Behaviour
def apply_flocking(positions, velocities):
    for i in range(N):
        pos_i = positions[:, i].reshape(2, 1)    # Selects only the i-th boid by selecting the i-th column x, y     # Shape (2,1)
        diffs = positions - pos_i                # Computes the column vector from boid i to another boid    # Shape (2, N)
        dists = np.linalg.norm(diffs, axis=0)    # Computes euclidean distances     # Shape (N,)
        is_neighbour = (dists > 0) & (dists < neighbor_radius)   # Neighbors
        if not np.any(is_neighbour):            # If the boid has no neighbours, skip to the next one
            continue
        # Normalize each vector to unit length & add all unit vectors for net repulsion direction
        
        separation = -np.sum(diffs[:, is_neighbour] / dists[is_neighbour], axis=1)   # Avoid crashing

        # Compute average velocity of nearby boids & subtract them from i's velocity for correction 
        
        alignment = np.mean(velocities[:, is_neighbour], axis=1) - velocities[:, i]  # Fly together

        # Get a vector pointing towards the center by taking the difference between the mean positions of neighbours and current boid's positions
        
        center_of_mass = np.mean(positions[:, is_neighbour], axis=1)   # Stay together
        cohesion = center_of_mass - positions[:, i]

        # Combine Rules
        
        velocities[:, i] += (
            separation_weight * separation +
            alignment_weight * alignment +
            cohesion_weight * cohesion
        )

def limit_velocity(velocities, max_speed=10):
    speeds = np.linalg.norm(velocities, axis=0)   # Compute the magnitude of each 2D vector
    too_fast = speeds > max_speed
    velocities[:, too_fast] *= (max_speed / speeds[too_fast])   # Scales down the velocity vector proportionally

velocities



# 7. BirdBoid Class
class BirdBoid:
    def __init__(self, ax, init_pos, init_vel,
                 body_size=(30, 20), head_radius=6,
                 body_color='skyblue', head_color='navy'):
        self.body = Ellipse(
            xy=init_pos,
            width=body_size[0],
            height=body_size[1],
            angle=0,
            facecolor=body_color,
            edgecolor='black'
        )
        self.head = Circle(
            xy=init_pos,
            radius=head_radius,
            facecolor=head_color,
            edgecolor='black'
        )                           # Template to create bird shaped boids
        ax.add_patch(self.body)
        ax.add_patch(self.head)     # Puts the shape on the axes like attaching a sticker to a canvas

    # Move and rotate bird each frame
    
    def update(self, pos, vel):           # Gets called every animation frame to update each bird's shape
        angle_deg = np.arctan2(vel[1], vel[0]) * 180 / np.pi    # Calculates the angle the boid is flying; angle between the velocity vector and x-axis
        unit = vel / (np.linalg.norm(vel) + 1e-6)     # Unit vector to offset the head in the correct direction
        head_offset = unit * 10      # The head is moved 10 units in front of the body, in the direction the bird is flying                    
        
        # Update shape positions
        self.body.center = pos       # Moves the body to the current position
        self.body.angle = angle_deg  # Rotates the body so it alighns with flight direction
        self.head.center = pos + head_offset   # Moves the head in front of the body

print("BirdBoid class defined.")



# 8. Plot Setup
fig = plt.figure(figsize=(8, 8))
ax = plt.axes(xlim=(0, limits[0]), ylim=(0, limits[1]))

bird_boids = [BirdBoid(ax, positions[:, i], velocities[:, i]) for i in range(N)]     # Calls the birdboid class like a function then runs the init method inside the class

plt.title(f"N = {N} boids")
plt.show()



# 9. Animation Function
def animate(frame):
    apply_flocking(positions, velocities)
    limit_velocity(velocities)
    update_boids(positions, velocities)
    apply_boundary_collision(positions, velocities, limits)

    for i, bird in enumerate(bird_boids):        # Enumerate lets us pair a bird to its paticular position and velocity
        bird.update(positions[:, i], velocities[:, i])      # Calls the update function to match the visuals with the physics of motion

    # Dynamic Zoom
    min_x, max_x = np.min(positions[0]), np.max(positions[0])      # Leftmost bird and rightmost bird
    min_y, max_y = np.min(positions[1]), np.max(positions[1])      # Lowest bird and highest bird
    
    # Set offset so birds aren't at the edge
    
    offset = 800
    min_x, max_x = max(0, min_x - offset), min(limits[0], max_x + offset)   # Prevents zooming to the left of 0 and to the right beyond the limit
    min_y, max_y = max(0, min_y - offset), min(limits[1], max_y + offset)   # Prevents zooming under 0 and above the limit
    
    # Point the camera so the flock always stays centered
    
    ax.set_xlim(min_x, max_x)
    ax.set_ylim(min_y, max_y)

print("Animation function ready.")



# 10. Run Animation
anim = animation.FuncAnimation(fig, animate, frames=1000, interval=50)
rc('animation', embed_limit=500)
HTML(anim.to_jshtml())




